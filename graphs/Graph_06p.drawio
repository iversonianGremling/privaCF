        </mxCell>
        <mxCell id="-4gnWyPn8esLxgZOmn1w-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="Simple CF sharing + VPN + PSI Handshake + noisy/chopped vector (uniform size) + Identity rotation + Loopix + Regular timings + Decoy messages + decoy aware local system" vertex="1">
          <mxGeometry height="70" width="320" x="275" y="90" as="geometry" />
        </mxCell>
        <mxCell id="-4gnWyPn8esLxgZOmn1w-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="PRIVACY&lt;br&gt;Everyone can see each others:&lt;br&gt;- Approximate similarity with their own taste vector without a permanent identity&lt;br&gt;- Can&#39;t see their real IP&lt;div&gt;- Can know that they are using a VPN&lt;br&gt;- Timing metadata becomes obfuscated&lt;br&gt;- Package size is obfuscated&lt;br&gt;&lt;br&gt;Deanonymizing a user becomes very hard. &lt;br&gt;Tracking a user&#39;s taste is possible after overtime observation through probabilistic means but VERY hard&lt;br&gt;Tracking a user directly is not possible&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="450" x="200" y="500" as="geometry" />
        </mxCell>
        <mxCell id="-4gnWyPn8esLxgZOmn1w-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="SYBIL RESISTANCE (to contamination of vectors)&lt;br&gt;Non existent, made worse because of identity rotation&lt;br&gt;&lt;br&gt;SYBIL RESISTANCE (to deanonymization)&lt;br&gt;Not possible inside of the network&lt;br&gt;Still possible trough other channels with the information gathered from the network but requires overtime observation. VERY hard for adversaries" vertex="1">
          <mxGeometry height="100" width="450" x="200" y="750" as="geometry" />
        </mxCell>
        <mxCell id="-4gnWyPn8esLxgZOmn1w-14" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="MESSAGES&lt;br&gt;- PSI handhsake&lt;br&gt;- Noised/chopped version of the vectors shared" vertex="1">
          <mxGeometry height="80" width="450" x="200" y="880" as="geometry" />
        </mxCell>
