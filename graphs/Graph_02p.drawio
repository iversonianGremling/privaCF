        <mxCell id="-4gnWyPn8esLxgZOmn1w-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="Simple CF sharing + VPN + PSI Handshake + noisy/chopped vector (uniform size with decoys)" vertex="1">
